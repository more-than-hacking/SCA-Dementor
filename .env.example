# Dementor — The SCA Hunter — environment variables
# Copy to .env and fill in your values:  cp .env.example .env
# (Anything set here is also settable in config/org_config.yaml; env vars win.)

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token — needs `repo` (private) or `public_repo` scope to clone,
# plus `read:org` if you scan a whole org.
GITHUB_TOKEN=ghp_your_token_here

# Org / owner whose repos you scan (also accepts a single owner for public repos).
ORG_NAME=your-github-org

# ── LLM provider (bring your own key) ────────────────────────────────────────
# Unlocks the AI reachability/exploitability engine. Without it, the deterministic
# layers (OSV + transitive + EPSS/KEV) still run.
#   provider: gemini | openai | anthropic
LLM_PROVIDER=gemini

# Gemini free tier works for demos. Get a key: https://aistudio.google.com/apikey
LLM_API_KEY=your_llm_api_key_here

# Model (defaults per provider if blank). Cheap + capable default:
LLM_MODEL=gemini-2.5-flash

# Optional: custom OpenAI-compatible endpoint (leave blank for the provider default).
LLM_API_URL=

# ── Optional tuning ──────────────────────────────────────────────────────────
# Parallel reachability workers (raise for paid keys, lower on free tier to avoid 429s).
# REACHABILITY_WORKERS=4
# Rate-limit backoff (free tiers 429 often):
# LLM_MAX_RETRIES=5
# LLM_BACKOFF_BASE=2
# LLM_BACKOFF_MAX=60
# Override cost estimate pricing (USD per 1M tokens):
# LLM_PRICE_IN=0.30
# LLM_PRICE_OUT=2.50

